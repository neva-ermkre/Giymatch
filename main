package com.giymatch.view;
import com.giymatch.model.VeritabaniBaglantisi;

import javafx.application.Application;
import javafx.fxml.FXMLLoader;
import javafx.scene.Parent;
import javafx.scene.Scene;
import javafx.stage.Stage;

public class Main extends Application { // burası javafx uygulaması alanı, pencere açılır
  
    @Override
    public void start(Stage primaryStage) throws Exception { //ana uygulama penceresi primaryStace
        VeritabaniBaglantisi.sistemiBaslat(); //veritabanını en başta kontrol eder
        
        Parent root = FXMLLoader.load(getClass().getResource("girisEkrani.fxml"));//ana ekran tasarımını koda aktarır
        primaryStage.setTitle("Giymatch Uygulaması"); //pencerenin en üstünde yazılan yazı
        primaryStage.setScene(new Scene(root, 600, 400)); //pencerenin boyutunu belirler
        primaryStage.show(); //pencereyi görünür hale getirir
    }

    public static void main(String[] args) { //program başlatıldı
        launch(args); //javafx sistemini çalıştırır
    }
}
